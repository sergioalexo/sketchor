{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sketchor",
  "version": "0.2.0",
  "identifier": "com.sketchor.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Sketchor",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sergioalexo/sketchor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxMkUyNzExOTRFNkEzOUEKUldTYW8rYVVFU2N1MGNjTVkxWmpxZDI2LzZGNjJaYlA1Zmh6cFh4SHZzQlJ3Tjh1bFpESlRYVHEK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["dxf"],
        "name": "DXF Drawing",
        "description": "AutoCAD DXF drawing",
        "role": "Editor"
      }
    ]
  }
}
