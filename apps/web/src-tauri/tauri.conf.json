{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sketchor",
  "version": "0.3.1",
  "identifier": "com.sketchor.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../native/build-shell-extensions.ps1 && npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Sketchor",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [
      "shell-ext/sketchor_shell.dll",
      "shell-ext/dxf_thumbnailer.dll"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["dxf"],
        "name": "DXF Drawing",
        "description": "AutoCAD DXF drawing",
        "role": "Editor"
      },
      {
        "ext": ["sketchor"],
        "name": "Sketchor Drawing",
        "description": "Sketchor native drawing",
        "mimeType": "application/x-sketchor",
        "role": "Editor"
      }
    ]
  }
}
